aws_region              = "us-east-1"
project_name          = "eventpro"
environment         = "prod"
frontend_bucket_name = "eventpro-prod-frontend"
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_username        = "admin"
db_password        = "your-secure-password-here"
vpc_cidr            = "10.0.0.0/16"
ecs_cluster_min_size = 1
ecs_cluster_max_size = 4
ecs_cluster_desired_capacity = 2
frontend_docker_image = "your-account-id.dkr.ecr.us-east-1.amazonaws.com/frontend:latest"
backend_docker_image = "your-account-id.dkr.ecr.us-east-1.amazonaws.com/backend:latest"
certificate_arn    = "arn:aws:acm:us-east-1:123456789012:certificate/abc-123"
domain_name       = "example.com"
price_class     = "PriceClass_100"